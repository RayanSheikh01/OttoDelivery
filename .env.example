# ── Map provider (geocode / routing / traffic / matrix) ─────────────────────
# Default provider is Mapbox. One token covers geocoding v6, directions
# (driving-traffic), and the matrix API.
MAP_PROVIDER=mapbox
MAPBOX_TOKEN=

# Service area used by geocode.validate. An address geocodes fine but is
# "out-of-range" if it falls outside this radius from the center.
OTTO_SERVICE_CENTER_LAT=40.7128
OTTO_SERVICE_CENTER_LNG=-74.0060
OTTO_SERVICE_RADIUS_M=40000

# Minimum geocode confidence (0-1). Below this, geocode.geocode REFUSES rather
# than returning a low-confidence pin.
OTTO_GEOCODE_MIN_CONFIDENCE=0.5

# ── notify.send (customer messaging) ────────────────────────────────────────
# If Twilio creds are absent, notify.send runs in DRY-RUN: it logs the message
# against the order and returns status "dry_run" instead of texting a person.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=              # SMS sender, e.g. +15005550006
SENDGRID_API_KEY=         # optional, for channel=email
SENDGRID_FROM=            # verified sender address

# ── payments.charge / payments.refund ───────────────────────────────────────
# If STRIPE_SECRET_KEY is absent, payments run in DRY-RUN and never move money.
STRIPE_SECRET_KEY=
